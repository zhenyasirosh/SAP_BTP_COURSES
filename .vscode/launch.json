{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "CAP: cds serve debug",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "exec",
        "--",
        "cds",
        "serve",
        "all",
        "--with-mocks"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}